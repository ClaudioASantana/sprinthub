    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@iflow-mcp/dbeaver-mcp-server": "^1.2.3"
  }
}
